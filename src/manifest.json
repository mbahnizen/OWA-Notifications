{
  "manifest_version": 2,
  "name": "Outlook Web App Notifications",
  "short_name": "OWA Notifications",
  "description": "Transforms OWA with smart notifications, priority folder monitoring, and periodic summaries. Features a modern UI with seamless auto-scan and custom alerts.",
  "version": "2.0",
  "author": "mbahnizen",
  "icons": {
    "48": "icon.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/owa/*",
        "https://outlook.live.com/mail/*",
        "https://outlook.office365.com/mail/*",
        "https://outlook.office.com/mail/*",
        "https://mail.atisicloud.com/owa/*"
      ],
      "js": [
        "content-script.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "owa_notifications@mbahnizen",
      "strict_min_version": "128.0"
    }
  }
}